# MongoDB Atlas Configuration

# Get your connection string from:
# https://www.mongodb.com/cloud/atlas
# 
# Steps:
# 1. Go to site above and create FREE account
# 2. Create a cluster named "dinegrid"
# 3. In Clusters → Connect → Drivers, copy your connection string
# 4. Replace the line below with your actual connection string
# 5. Save this file
# 6. Run: node start.js

MONGODB_URI=mongodb+srv://dinegrid:PASSWORD@cluster0.mongodb.net/dinegrid?retryWrites=true&w=majority

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SUBHAMDAXXX

# Port
PORT=5000

# Debug mode
DEBUG=true
